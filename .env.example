AGENT_URL=http://localhost:8123

# genui server (FastAPI relying party on :8200). The Next.js /present/[token]
# route fetches public capability-token reads from SERVER_ORIGIN; the agent's
# present_to_human tool also uses it for team-auth artifact/link writes.
SERVER_ORIGIN=http://localhost:8200
# Optional cwd for `aw id request --team-auth` when the agent process runs
# outside an initialized aw workspace.
# GENUI_AW_CWD=

# Per-agent endpoints served by agent/main.py (FastAPI on :8123).
# Note: the /legal example's UI is currently a WIP stub (the endpoint works).
FIXED_AGENT_URL=http://localhost:8123/fixed
DYNAMIC_AGENT_URL=http://localhost:8123/dynamic
LEGAL_AGENT_URL=http://localhost:8123/legal

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# LLM PROVIDER — Default is Gemini 3.5 Flash via the NATIVE Google Gen AI
# SDK (langchain-google-genai). Get a free-tier key (no credit card):
# https://aistudio.google.com/apikey
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Required for the live concierge demo (/fixed and /dynamic call Gemini).
GEMINI_API_KEY=

# Required for live web research. OFFLINE=1 uses a canned research surface.
LINKUP_API_KEY=

# Optional model-ID override. Read by the ChatGoogleGenerativeAI(...) call
# in agent/src/research_agent.py (fixed/dynamic are compatibility modules that
# import the shared research concierge; default: gemini-3.5-flash — FROZEN,
# see FROZEN.md).
# MODEL=gemini-3.5-flash

# ─── Swapping providers (advanced — the default is FROZEN) ────
# The provider is code, not env: the model client is constructed in the three
# agent files above (ChatGoogleGenerativeAI). To swap, replace those
# constructor calls — e.g. for Anthropic:
#   from langchain_anthropic import ChatAnthropic
#   model = ChatAnthropic(model="claude-opus-4-7", api_key=os.getenv("ANTHROPIC_API_KEY"))
# langchain-openai / langchain-anthropic are already in agent/pyproject.toml.
# CAUTION: Gemini 3.x via the OpenAI-compat endpoint breaks on multi-turn
# tool calls (thought-signature replay) — the supported fallback is
# OpenAI-compat + gemini-2.5-flash, documented in FROZEN.md § LLM provider.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# ─── Offline mode ─────────────────────────────────────────────
# Set OFFLINE=1 to make the research concierge serve a built-in cited LinkUp
# research A2UI surface with NO Gemini or LinkUp call and no API key — handy for
# a venue-Wi-Fi fallback or a key-less first look. /fixed and /dynamic are
# compatibility routes that import the same concierge; /legal still requires
# GEMINI_API_KEY. `pnpm smoke` exercises this path (offline /fixed probe).
# OFFLINE=

# ─── A2A bolt-on (Track 1 interop — Seam #6) ──────────────────
# Dormant unless set. Run `pnpm check-a2a <url>` BEFORE setting this.
# Comma-separate to point at multiple partner agents. See HACKATHON.md §6
# (including the current limitation: the seam wraps the legal agent, not
# the pdf-analyst agents).
# A2A_AGENT_URL=
# A2A_INSTRUCTIONS=

# ─── genui server (AWID team-cert artifact spine) ─────────────
# FastAPI server defaults to :8200. Agents sign this public origin as the
# team-auth audience and POST artifacts/presentation links here.
GENUI_SERVER_PUBLIC_ORIGIN=http://127.0.0.1:8200
# Optional frontend origin used in minted presentation URLs. Keep PUBLIC_ORIGIN
# as the server/API origin that aw signs for cert-auth requests.
GENUI_SERVER_PRESENTATION_ORIGIN=http://127.0.0.1:3000
GENUI_SERVER_DATABASE_URL=postgresql://localhost/genui
GENUI_SERVER_AWID_REGISTRY_URL=https://api.awid.ai
# GENUI_SERVER_DEFAULT_PRESENT_TTL_SECONDS=86400
# GENUI_SERVER_MAX_PRESENT_TTL_SECONDS=604800
