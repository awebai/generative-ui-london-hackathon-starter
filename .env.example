# genui server (FastAPI relying party on :8200). Agents sign this public
# origin as the team-auth audience for aw id request --team-auth calls.
SERVER_ORIGIN=http://localhost:8200

# Next.js /present/[token] fetches public capability-token reads from SERVER_ORIGIN.
# No LangGraph concierge sidecar is required.

# Server-side LinkUp key for POST /v1/search. Keep this on the server, not in
# browser/client code.
LINKUP_API_KEY=

# Optional frontend origin used in minted presentation URLs. Keep PUBLIC_ORIGIN
# as the server/API origin that aw signs for cert-auth requests.
GENUI_SERVER_PUBLIC_ORIGIN=http://127.0.0.1:8200
GENUI_SERVER_PRESENTATION_ORIGIN=http://127.0.0.1:3000
GENUI_SERVER_DATABASE_URL=postgresql://localhost/genui
# For production/real demos, omit GENUI_SERVER_AWID_REGISTRY_URL so the default
# real registry https://api.awid.ai is used.
# GENUI_SERVER_AWID_REGISTRY_URL=https://api.awid.ai
# GENUI_SERVER_DEFAULT_PRESENT_TTL_SECONDS=86400
# GENUI_SERVER_MAX_PRESENT_TTL_SECONDS=604800

# A2A bolt-on (Track 1 interop — optional/stretch).
# A2A_AGENT_URL=
# A2A_INSTRUCTIONS=
